{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "frontend": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfile": "frontend/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "healthcheckPath": "/",
        "healthcheckTimeout": 100
      }
    },
    "backend": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfile": "backend/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "healthcheckPath": "/",
        "healthcheckTimeout": 100
      }
    }
  }
}
